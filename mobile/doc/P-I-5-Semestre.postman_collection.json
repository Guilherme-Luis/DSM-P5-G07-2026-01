          "name": "Login-User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "\r",
                  "if (response.token) {\r",
                  "    const token = response.token;\r",
                  "\r",
                  "    pm.collectionVariables.set(\"authTokenUser\", token);\r",
                  "\r",
                  "    const payload = JSON.parse(atob(token.split('.')[1]));\r",
                  "    pm.collectionVariables.set(\"UserID\", payload.userId);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
